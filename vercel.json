{
    "routes": [
        {
            "src": "/php/(.*).php",
            "dest": "/api/$1"
        },
        {
            "src": "/api/(.*).php",
            "dest": "/api/$1"
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*)",
            "dest": "/$1"
        }
    ]
}